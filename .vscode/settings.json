{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "terminal.integrated.profiles.linux": {
    "tmux": {
      "path": "bash",
      "args": ["-c", "tmux new -ADs ${PWD##*/}"],
      "icon": "terminal-tmux"
    }
  },
  "terminal.integrated.defaultProfile.linux": "tmux",
  "terminal.integrated.rightClickBehavior": "nothing",
  "devcontainersTerminalImagePaste.enabled": true,
  "devcontainersTerminalImagePaste.saveDir": "./.tmp/terminal-pastes",
  "devcontainersTerminalImagePaste.fileNamePattern": "clipboard-{timestamp}.png"
}
